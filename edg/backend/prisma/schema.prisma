generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model SysUser {
  id             String      @id @default(uuid())
  username       String      @unique
  password_hash  String
  role           String
  campus_id      String?
  status         String      @default("ACTIVE")
  createdAt      DateTime    @default(now())
  campusName     String?
  address        String?
  studentProfile EduStudent?
  teacherProfile EduTeacher?
}

model EduStudent {
  id              String                    @id @default(uuid())
  name            String
  gender          String?
  phone           String?                   @unique
  balance         Float                     @default(0) // @deprecated 钱包概念已废弃，退费直接退回原渠道，保留仅供历史兼容
  status          String                    @default("ACTIVE")
  user_id         String                    @unique
  createdAt       DateTime                  @default(now())
  user            SysUser                   @relation(fields: [user_id], references: [id])
  classes         EduStudentInClass[]
  accounts        FinAssetAccount[]
  orders          FinOrder[]
  refunds         FinRefundRecord[]
  lessonProgress  StudentLessonProgress[]
  attendances     TeachAttendance[]
  submissions     TeachHomeworkSubmission[]
  leaveRequests   LeaveRequest[]
  statusLogs      StudentStatusLog[]
  quizSubmissions QuizSubmission[]
}

model EduTeacher {
  id         String  @id @default(uuid())
  name       String
  department String?
  user_id    String  @unique
  user       SysUser @relation(fields: [user_id], references: [id])

  assignments EdClassAssignment[]
  courses     EdCourse[]
  homeworks   TeachHomework[]
}

model EdCourse {
  id              String                  @id @default(uuid())
  name            String
  category        String
  price           Float
  total_lessons   Int
  status          String                  @default("ENABLED")
  standard_id     String
  duration        Int                     @default(45)
  campus_id       String?
  instructor_id   String?
  assignments     EdClassAssignment[]
  instructor      EduTeacher?             @relation(fields: [instructor_id], references: [id])
  standard        StdCourseStandard       @relation(fields: [standard_id], references: [id])
  accounts        FinAssetAccount[]
  orders          FinOrder[]
  lessonProgress  StudentLessonProgress[]
  schedules       EdLessonSchedule[]
  quizSubmissions QuizSubmission[]
}

model EdClass {
  id        String @id @default(uuid())
  name      String
  capacity  Int
  enrolled  Int    @default(0)
  campus_id String
  status    String @default("ONGOING")

  assignments EdClassAssignment[]
  students    EduStudentInClass[]
}

model EdClassAssignment {
  id         String @id @default(uuid())
  class_id   String
  course_id  String
  teacher_id String

  class   EdClass    @relation(fields: [class_id], references: [id])
  course  EdCourse   @relation(fields: [course_id], references: [id])
  teacher EduTeacher @relation(fields: [teacher_id], references: [id])

  status    String   @default("ACTIVE") // ACTIVE, COMPLETED, CANCELLED
  createdAt DateTime @default(now())

  schedules EdLessonSchedule[]
  homeworks TeachHomework[]

  @@unique([class_id, course_id])
}

model EduStudentInClass {
  student_id String
  class_id   String
  enrolledAt DateTime   @default(now())
  class      EdClass    @relation(fields: [class_id], references: [id])
  student    EduStudent @relation(fields: [student_id], references: [id])

  @@id([student_id, class_id])
}

model EdLessonSchedule {
  id            String            @id @default(uuid())
  assignment_id String
  assignment    EdClassAssignment @relation(fields: [assignment_id], references: [id])
  course_id     String? // 冗余字段，简化课消扣费等高频查询的 JOIN 链路
  course        EdCourse?         @relation(fields: [course_id], references: [id])

  lesson_no    Int      @default(1)
  start_time   DateTime
  end_time     DateTime
  classroom    String?
  classroom_id String?
  status       String   @default("SCHEDULED")
  is_consumed  Boolean  @default(false)

  attendances   TeachAttendance[]
  leaveRequests LeaveRequest[]
  room          EduClassroom?     @relation(fields: [classroom_id], references: [id])

  @@unique([assignment_id, lesson_no])
}

model EduClassroom {
  id        String   @id @default(uuid())
  name      String
  campus_id String
  status    String   @default("AVAILABLE")
  createdAt DateTime @default(now())

  schedules EdLessonSchedule[]

  @@unique([campus_id, name])
}

model FinOrder {
  id           String             @id @default(uuid())
  student_id   String
  course_id    String
  amount       Float
  total_qty    Int                @default(1)
  order_source String             @default("student")
  operator_id  String?
  status       String             @default("PENDING_PAYMENT")
  createdAt    DateTime           @default(now())
  course       EdCourse           @relation(fields: [course_id], references: [id])
  student      EduStudent         @relation(fields: [student_id], references: [id])
  payments     FinPaymentRecord[]
  refunds      FinRefundRecord[]
}

model FinPaymentRecord {
  id          String   @id @default(uuid())
  order_id    String
  amount      Float
  channel     String
  status      String   @default("SUCCESS")
  operator_id String?
  createdAt   DateTime @default(now())
  order       FinOrder @relation(fields: [order_id], references: [id])
}

model FinRefundRecord {
  id               String           @id @default(uuid())
  order_id         String
  account_id       String?
  student_id       String
  requested_qty    Float            @default(0)
  approved_qty     Float?
  estimated_amount Float?
  amount           Float            @default(0)
  refund_channel   String? // 退回渠道（与原支付渠道一致）
  reason           String
  // 状态: PENDING | APPROVED | REJECTED | PROCESSING | PROCESSED
  status           String           @default("PENDING")
  applicant_id     String
  approver_id      String?
  review_note      String?
  createdAt        DateTime         @default(now())
  reviewedAt       DateTime?
  updatedAt        DateTime         @updatedAt
  student          EduStudent       @relation(fields: [student_id], references: [id])
  order            FinOrder         @relation(fields: [order_id], references: [id])
  account          FinAssetAccount? @relation(fields: [account_id], references: [id])
}

// 校区配置表（退费阈值等可配置项）
model CampusConfig {
  campus_id                 String   @id
  refund_approval_threshold Float    @default(1000)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model FinAssetAccount {
  id              String            @id @default(uuid())
  student_id      String
  course_id       String
  campus_id       String
  total_qty       Float
  remaining_qty   Float
  locked_qty      Float             @default(0)
  refunded_qty    Float             @default(0)
  refunded_amount Float             @default(0)
  status          String            @default("ACTIVE")
  updatedAt       DateTime          @updatedAt
  course          EdCourse          @relation(fields: [course_id], references: [id])
  student         EduStudent        @relation(fields: [student_id], references: [id])
  ledgers         FinAssetLedger[]
  refunds         FinRefundRecord[]
}

model FinAssetLedger {
  id               String          @id @default(uuid())
  account_id       String
  type             String
  change_qty       Float
  balance_snapshot Float
  ref_id           String?
  occurTime        DateTime        @default(now())
  account          FinAssetAccount @relation(fields: [account_id], references: [id])
}

model TeachAttendance {
  id            String           @id @default(uuid())
  lesson_id     String
  student_id    String
  status        String
  deduct_status String           @default("PENDING") // PENDING | DEDUCTED | FAILED_INSUFFICIENT_BALANCE | REVOKED
  deduct_amount Float            @default(0)
  revoked_at    DateTime? // 课消撤销时间
  createdAt     DateTime         @default(now())
  student       EduStudent       @relation(fields: [student_id], references: [id])
  lesson        EdLessonSchedule @relation(fields: [lesson_id], references: [id])
}

model TeachHomework {
  id             String                    @id @default(uuid())
  title          String
  content        String
  deadline       DateTime
  assignment_id  String
  class_id       String? // 冗余字段，简化学员查询作业的 JOIN
  teacher_id     String
  lesson_id      String?
  createdAt      DateTime                  @default(now())
  attachmentName String?
  attachmentUrl  String?
  teacher        EduTeacher                @relation(fields: [teacher_id], references: [id])
  assignment     EdClassAssignment         @relation(fields: [assignment_id], references: [id])
  lesson         StdCourseLesson?          @relation(fields: [lesson_id], references: [id])
  submissions    TeachHomeworkSubmission[]
}

model TeachHomeworkSubmission {
  id               String        @id @default(uuid())
  homework_id      String
  student_id       String
  content          String
  score            Float?
  feedback         String?
  // 状态: SUBMITTED | GRADED | LATE | RETURNED
  status           String        @default("SUBMITTED")
  submission_count Int           @default(1) // 提交次数（用于退回重交）
  submittedAt      DateTime      @default(now())
  updatedAt        DateTime      @default(now()) @updatedAt
  student          EduStudent    @relation(fields: [student_id], references: [id])
  homework         TeachHomework @relation(fields: [homework_id], references: [id])
}

model LeaveRequest {
  id          String    @id @default(uuid())
  lesson_id   String
  student_id  String
  campus_id   String?
  reason      String
  status      String    @default("PENDING")
  approver_id String?
  review_note String?
  createdAt   DateTime  @default(now())
  reviewedAt  DateTime?
  updatedAt   DateTime  @updatedAt

  lesson  EdLessonSchedule @relation(fields: [lesson_id], references: [id])
  student EduStudent       @relation(fields: [student_id], references: [id])

  @@index([lesson_id, student_id])
}

model SysAuditLog {
  id          String   @id @default(uuid())
  action      String
  entity_type String
  entity_id   String
  operator_id String?
  details     String?
  createdAt   DateTime @default(now())
}

model SysAnnouncement {
  id           String                  @id @default(uuid())
  title        String
  content      String
  status       String                  @default("DRAFT")
  scope        String                  @default("ALL")
  publisher_id String
  publishTime  DateTime?
  withdrawTime DateTime?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  targets      SysAnnouncementTarget[]
}

model SysAnnouncementTarget {
  id              String          @id @default(uuid())
  announcement_id String
  campus_id       String
  announcement    SysAnnouncement @relation(fields: [announcement_id], references: [id])
}

model StdCourseCategory {
  id          String              @id @default(uuid())
  name        String              @unique
  description String?
  sort_order  Int                 @default(0)
  status      String              @default("ENABLED")
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  standards   StdCourseStandard[]
}

model StdCourseStandard {
  id                 String                    @id @default(uuid())
  code               String                    @unique
  name               String
  category_id        String
  age_min            Int?
  age_max            Int?
  description        String?
  total_lessons      Int
  lesson_duration    Int                       @default(45)
  suggested_cycle    String?
  suggested_capacity Int                       @default(20)
  status             String                    @default("DRAFT")
  version            Int                       @default(1)
  creator_id         String
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  cover_url          String?
  courses            EdCourse[]
  chapters           StdCourseChapter[]
  category           StdCourseCategory         @relation(fields: [category_id], references: [id])
  campuses           StdCourseStandardCampus[]
  templates          StdCourseTemplate[]
  versions           StdCourseVersion[]
  resources          StdResource[]
}

model StdCourseStandardCampus {
  id          String            @id @default(uuid())
  standard_id String
  campus_id   String
  createdAt   DateTime          @default(now())
  standard    StdCourseStandard @relation(fields: [standard_id], references: [id])

  @@unique([standard_id, campus_id])
}

model StdCourseTemplate {
  id              String            @id @default(uuid())
  standard_id     String
  teaching_goal   String?
  stage_desc      String?
  default_fee_ref Float?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  standard        StdCourseStandard @relation(fields: [standard_id], references: [id])
}

model StdCourseVersion {
  id          String            @id @default(uuid())
  standard_id String
  version     Int
  snapshot    String
  change_note String?
  operator_id String
  createdAt   DateTime          @default(now())
  standard    StdCourseStandard @relation(fields: [standard_id], references: [id])
}

model StdResource {
  id          String              @id @default(uuid())
  title       String
  type        String
  url         String
  file_name   String?
  file_size   Int?
  description String?
  status      String              @default("DRAFT")
  standard_id String?
  creator_id  String
  sort_order  Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  lessonLinks StdLessonResource[]
  standard    StdCourseStandard?  @relation(fields: [standard_id], references: [id])
}

model StdCourseChapter {
  id          String            @id @default(uuid())
  standard_id String
  title       String
  sort_order  Int               @default(0)
  createdAt   DateTime          @default(now())
  standard    StdCourseStandard @relation(fields: [standard_id], references: [id])
  lessons     StdCourseLesson[]
  quizPapers  QuizPaper[]
}

model StdCourseLesson {
  id         String                  @id @default(uuid())
  chapter_id String
  title      String
  sort_order Int                     @default(0)
  duration   Int?
  createdAt  DateTime                @default(now())
  chapter    StdCourseChapter        @relation(fields: [chapter_id], references: [id])
  resources  StdLessonResource[]
  progress   StudentLessonProgress[]
  homeworks  TeachHomework[]
}

model StdLessonResource {
  id          String          @id @default(uuid())
  lesson_id   String
  resource_id String
  sort_order  Int             @default(0)
  resource    StdResource     @relation(fields: [resource_id], references: [id])
  lesson      StdCourseLesson @relation(fields: [lesson_id], references: [id])

  @@unique([lesson_id, resource_id])
}

model StudentLessonProgress {
  id           String          @id @default(uuid())
  student_id   String
  course_id    String
  lesson_id    String
  status       String          @default("NOT_STARTED")
  started_at   DateTime?
  completed_at DateTime?
  updatedAt    DateTime        @updatedAt
  lesson       StdCourseLesson @relation(fields: [lesson_id], references: [id])
  course       EdCourse        @relation(fields: [course_id], references: [id])
  student      EduStudent      @relation(fields: [student_id], references: [id])

  @@unique([student_id, lesson_id, course_id])
}

// ─── 学员状态日志 ──────────────────────────────────────────────────
model StudentStatusLog {
  id          String     @id @default(uuid())
  student_id  String
  from_status String
  to_status   String
  reason      String?
  operator_id String
  createdAt   DateTime   @default(now())
  student     EduStudent @relation(fields: [student_id], references: [id])
}

// ─── 测验系统 (Quiz) ──────────────────────────────────────────────
model QuizPaper {
  id          String           @id @default(uuid())
  title       String
  chapter_id  String
  standard_id String
  time_limit  Int              @default(1200)
  pass_score  Float            @default(60)
  status      String           @default("DRAFT")
  creator_id  String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  chapter     StdCourseChapter @relation(fields: [chapter_id], references: [id])
  questions   QuizQuestion[]
  submissions QuizSubmission[]
}

model QuizQuestion {
  id         String    @id @default(uuid())
  paper_id   String
  type       String // single | multiple
  text       String
  options    String // JSON
  answer     String // JSON
  score      Float     @default(10)
  sort_order Int       @default(0)
  paper      QuizPaper @relation(fields: [paper_id], references: [id])
}

model QuizSubmission {
  id          String     @id @default(uuid())
  paper_id    String
  student_id  String
  course_id   String
  answers     String // JSON
  score       Float      @default(0)
  total_score Float      @default(0)
  passed      Boolean    @default(false)
  time_spent  Int        @default(0)
  submittedAt DateTime   @default(now())
  paper       QuizPaper  @relation(fields: [paper_id], references: [id])
  student     EduStudent @relation(fields: [student_id], references: [id])
  course      EdCourse   @relation(fields: [course_id], references: [id])
}
